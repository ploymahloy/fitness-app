{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug executable 'fitness-app'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--bin=fitness-app",
                    "--manifest-path=${workspaceFolder}/server/Cargo.toml"
                ],
                "filter": {
                    "name": "fitness-app",
                    "kind": "bin"
                },
                "cwd": "${workspaceFolder}/server"
            },
            "args": [],
            "cwd": "${workspaceFolder}/server",
            "sourceLanguages": ["rust"]
        }
    ]
}